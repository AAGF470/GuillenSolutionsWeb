# ── guillensolutions.com CMS — copy to .env and fill in on RAYA ──────────────
# docker compose reads this file for ${DB_PASSWORD} interpolation AND passes it
# into the container via env_file. DATABASE_URL is overridden in compose to point
# at the internal db service, so you only set DB_PASSWORD here.

# Postgres password (used for both the db container and the connection string).
DB_PASSWORD=change-me-long-random

# Long random string — signs sessions/tokens. Generate: openssl rand -hex 32
PAYLOAD_SECRET=change-me-openssl-rand-hex-32

# Public URL of the admin/API (what NPM routes to this container).
PAYLOAD_PUBLIC_SERVER_URL=https://cms.guillensolutions.com

# The site origin allowed to fetch the API (CORS/CSRF). The public website.
SITE_URL=https://guillensolutions.com

# For LOCAL dev only (docker overrides this in prod). Point at a local Postgres:
# DATABASE_URL=postgres://payload:payload@127.0.0.1:5432/payload
